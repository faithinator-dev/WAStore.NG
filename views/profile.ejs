<div class="max-w-md mx-auto w-full p-4">
    <div class="flex items-center gap-4 mb-6">
        <a href="/admin" class="text-2xl">←</a>
        <h1 class="text-2xl font-bold">Edit Profile</h1>
    </div>
    <form action="/admin/profile" method="POST" class="space-y-5">
        <div>
            <label class="block text-sm font-bold mb-1">Shop Name</label>
            <input type="text" name="shop_name" value="<%= vendor.shop_name %>" required class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Location</label>
            <input type="text" name="location" value="<%= vendor.location %>" placeholder="e.g. Lagos, Nigeria" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Bio / Slogan</label>
            <textarea name="bio" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500"><%= vendor.bio %></textarea>
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Instagram Username (Optional)</label>
            <input type="text" name="instagram" value="<%= vendor.instagram || '' %>" placeholder="e.g. mama_spices" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
        </div>

        <div>
            <label class="block text-sm font-bold mb-1">Delivery Info</label>
            <textarea name="delivery_info" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500"><%= vendor.delivery_info %></textarea>
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Opay Account (Optional)</label>
            <input type="text" name="payment_opay" value="<%= vendor.payment_opay || '' %>" placeholder="e.g. 1234567890" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Palmpay Account (Optional)</label>
            <input type="text" name="payment_palmpay" value="<%= vendor.payment_palmpay || '' %>" placeholder="e.g. 9876543210" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <button type="submit" class="w-full tap-target bg-emerald-600 text-white font-bold shadow-lg">Save Changes</button>
    </form>
</div>

