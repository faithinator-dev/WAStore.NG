<style>


.store-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    @media (min-width: 768px) { .store-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<header class="bg-emerald-600 text-white sticky top-0 z-40 shadow-lg">
    <div class="max-w-5xl mx-auto px-4 py-8 text-center">
        <h1 class="text-4xl font-black tracking-tight mb-2"><%= vendor.shop_name %></h1>
        <div class="text-sm opacity-90 font-bold uppercase tracking-widest flex items-center justify-center gap-3">
            <span>📍 <%= vendor.location %></span>
            <% if (vendor.instagram) { %>
                <span class="opacity-50">|</span>
                <a href="https://instagram.com/<%= vendor.instagram %>" target="_blank" class="flex items-center gap-1 hover:text-emerald-200 transition-colors">
                    📸 @<%= vendor.instagram %>
                </a>
            <% } %>
        </div>
    </div>
</header>

<div class="bg-white border-b border-gray-100 px-4 py-6 mb-8">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="max-w-2xl">
            <p class="text-gray-600 font-medium text-lg leading-relaxed"><%= vendor.bio %></p>
            <div class="mt-3 inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider">
                🚚 <%= vendor.delivery_info %>
            </div>
        </div>
    </div>
</div>

<main class="max-w-5xl mx-auto p-4 flex-grow pb-32">
    <% if (products.length === 0) { %>
        <div class="text-center py-24 bg-gray-50 rounded-[3rem] border border-dashed border-gray-200">
            <div class="text-6xl mb-4">🏪</div>
            <h3 class="text-xl font-black text-gray-900">Store Catalog is Empty</h3>
            <p class="text-gray-400 font-medium mt-2">The vendor hasn't uploaded any products yet.</p>
        </div>
    <% } else { %>
        <div class="store-grid">
            <% products.forEach(p => { %>
                <div class="bg-white rounded-[2rem] overflow-hidden shadow-sm border border-gray-100 flex flex-col transition-all hover:shadow-xl hover:-translate-y-1 group">
                    <div class="relative aspect-square overflow-hidden bg-gray-50">
                        <img src="<%= p.image_url || 'https://via.placeholder.com/400x400/10B981/ffffff?text=Product' %>" 
                             loading="lazy" class="w-full h-full object-cover transition-transform group-hover:scale-110">

                        <% if (p.stock_status === 'out_of_stock') { %>
                            <div class="absolute inset-0 bg-black/40 backdrop-blur-[2px] flex items-center justify-center">
                                <span class="bg-white text-black px-4 py-2 rounded-full text-xs font-black uppercase tracking-widest">Out of Stock</span>
                            </div>
                        <% } %>

                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex-grow">
                            <h3 class="text-lg font-black text-gray-900 leading-tight mb-2"><%= p.name %></h3>
                            <% if (p.short_description) { %>
                                <p class="text-gray-500 text-sm font-medium line-clamp-2 mb-4 leading-relaxed"><%= p.short_description %></p>
                            <% } %>

                            <% if (p.variants && p.variants.options && p.variants.options.length > 0) { %>
                                <div class="mb-4">
                                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-1"><%= p.variants.name %></label>
                                    <select id="variant-<%= p.$loki %>" class="w-full bg-gray-50 border border-gray-200 p-2 rounded-lg text-xs font-bold outline-emerald-600">
                                        <% p.variants.options.forEach(opt => { %>
                                            <option value="<%= opt %>"><%= opt %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            <% } %>
                        </div>
                        <div class="flex items-center justify-between mt-auto pt-4">
                            <div class="text-2xl font-black text-emerald-600 tracking-tight">₦<%= Number(p.price).toLocaleString() %></div>
                            <% if (p.stock_status !== 'out_of_stock') { %>
                                <button onclick="addToCart({id: '<%= p.$loki %>', name: '<%= p.name %>', price: <%= p.price %>, variant: document.getElementById('variant-<%= p.$loki %>')?.value || null})" class="w-12 h-12 bg-[#25D366] text-white rounded-2xl shadow-lg shadow-green-100 flex items-center justify-center hover:scale-110 transition-transform active:scale-95">
                                    🛒
                                </button>
                            <% } else { %>
                                <button onclick="window.open('https://wa.me/<%= vendor.whatsapp %>?text=Hi, when will <%= p.name %> be back in stock?')" class="text-xs font-black text-emerald-600 uppercase tracking-widest hover:underline">Notify Me</button>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</main>

<!-- CART DRAWER -->
<div id="cartDrawer" class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-50 hidden flex justify-end">
    <div class="w-full max-w-md bg-white h-full flex flex-col shadow-2xl animate-slide-in">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center">
            <h2 class="text-2xl font-black tracking-tight text-gray-900">Your Order 🛍️</h2>
            <button onclick="toggleCart()" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-gray-900 transition-colors">&times;</button>
        </div>
        <div id="cartItems" class="flex-grow overflow-y-auto p-6 space-y-6">
            <!-- Items injected here -->
        </div>
        <div class="p-8 border-t border-gray-100 bg-gray-50 space-y-4">
            <div class="flex justify-between text-xl font-black text-gray-900 mb-2">
                <span>Total Amount:</span>
                <span id="cartTotal" class="text-emerald-600 font-black">₦0</span>
            </div>
            
            <div class="space-y-3">
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Your Full Name</label>
                    <input type="text" id="buyerName" placeholder="John Doe" class="w-full p-3 rounded-xl border border-gray-200 text-sm font-medium outline-none focus:ring-2 focus:ring-emerald-500">
                </div>
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">WhatsApp Number</label>
                    <input type="tel" id="buyerPhone" placeholder="08012345678" class="w-full p-3 rounded-xl border border-gray-200 text-sm font-medium outline-none focus:ring-2 focus:ring-emerald-500">
                </div>
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Delivery Address</label>
                    <textarea id="buyerAddress" placeholder="Enter full address..." class="w-full p-3 rounded-xl border border-gray-200 text-sm font-medium outline-none focus:ring-2 focus:ring-emerald-500 min-h-[80px]"></textarea>
                </div>
            </div>

            <button onclick="checkout()" class="w-full py-4 bg-[#25D366] text-white rounded-2xl font-black text-lg shadow-xl shadow-green-100 hover:bg-[#21bf58] transition-all flex items-center justify-center gap-3 mt-4">
                Confirm Order on WhatsApp 🤳
            </button>
        </div>
    </div>
</div>

<!-- FLOATING CART BUTTON -->
<button id="cartButton" onclick="toggleCart()" class="fixed bottom-8 right-8 bg-emerald-600 text-white px-8 py-4 rounded-2xl shadow-2xl shadow-emerald-200 z-40 hidden flex items-center gap-3 font-black text-lg transition-all hover:scale-105 active:scale-95 animate-bounce">
    <span class="text-2xl">🛒</span>
    <span id="cartCount">0</span> Items
</button>

<a href="https://wa.me/<%= vendor.whatsapp %>" class="fixed bottom-8 left-8 w-16 h-16 bg-[#25D366] text-white rounded-2xl flex items-center justify-center shadow-2xl z-40 hover:scale-110 transition-transform active:scale-95">
    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.435 5.631 1.435h.008c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<script>
    let cart = JSON.parse(localStorage.getItem('wastore_cart') || '[]');

    function updateUI() {
        const count = cart.reduce((sum, item) => sum + item.qty, 0);
        const cartButton = document.getElementById('cartButton');
        const cartCount = document.getElementById('cartCount');
        const cartItems = document.getElementById('cartItems');
        const cartTotal = document.getElementById('cartTotal');

        cartCount.textContent = count;
        if (count > 0) cartButton.classList.remove('hidden');
        else cartButton.classList.add('hidden');

        cartItems.innerHTML = cart.length === 0 ? `
            <div class="text-center py-20">
                <div class="text-5xl mb-4">🛒</div>
                <p class="text-gray-400 font-bold uppercase tracking-widest text-xs">Your cart is empty</p>
            </div>
        ` : '';
        
        let total = 0;
        cart.forEach((item, index) => {
            total += item.price * item.qty;
            cartItems.innerHTML += `
                <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-[1.5rem] border border-gray-100">
                    <div class="flex-grow">
                        <div class="font-black text-gray-900 leading-tight">${item.name}</div>
                        ${item.variant ? `<div class="text-[10px] text-gray-400 uppercase font-black">${item.variant}</div>` : ''}
                        <div class="text-emerald-600 font-black">₦${item.price.toLocaleString()}</div>
                    </div>
                    <div class="flex items-center gap-4 bg-white px-4 py-2 rounded-2xl border border-gray-200">
                        <button onclick="updateQty(${index}, -1)" class="text-gray-400 font-black hover:text-red-500 transition-colors">-</button>
                        <span class="font-black text-gray-900 w-4 text-center">${item.qty}</span>
                        <button onclick="updateQty(${index}, 1)" class="text-emerald-600 font-black hover:text-emerald-700 transition-colors">+</button>
                    </div>
                </div>
            `;
        });
        cartTotal.textContent = '₦' + total.toLocaleString();
        localStorage.setItem('wastore_cart', JSON.stringify(cart));
    }

    function addToCart(product) {
        const existing = cart.find(item => item.id === product.id && item.variant === product.variant);
        if (existing) {
            existing.qty += 1;
        } else {
            cart.push({ ...product, qty: 1, quantity: 1 }); // Backend expects quantity
        }
        updateUI();
        showToast("Added to cart! 🛍️");
    }

    function updateQty(index, delta) {
        cart[index].qty += delta;
        cart[index].quantity = cart[index].qty; // Sync for backend
        if (cart[index].qty <= 0) cart.splice(index, 1);
        updateUI();
    }

    function toggleCart() {
        const drawer = document.getElementById('cartDrawer');
        drawer.classList.toggle('hidden');
    }

    function checkout() {
        const address = document.getElementById('buyerAddress').value.trim();
        const customerName = document.getElementById('buyerName').value.trim();
        const customerPhone = document.getElementById('buyerPhone').value.trim();
        
        if (!address || !customerName || !customerPhone) return alert("Please fill all details to continue!");
        
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/checkout';
        
        const fields = {
            vendor_id: '<%= vendor.$loki %>',
            customer_name: customerName,
            customer_phone: customerPhone,
            customer_address: address,
            cart_data: JSON.stringify(cart)
        };
        
        for (const key in fields) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = fields[key];
            form.appendChild(input);
        }
        
        document.body.appendChild(form);
        form.submit();
        
        localStorage.removeItem('wastore_cart');
    }

    updateUI();
</script>
