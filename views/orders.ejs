
<header class="bg-white border-b border-gray-200 px-4 h-16 flex items-center justify-between sticky top-0 z-30">
    <a href="/admin" class="font-bold text-emerald-600">← Back to Dashboard</a>
    <div class="text-xs font-bold text-gray-500 uppercase tracking-widest">Manage Orders</div>
</header>

<main class="max-w-xl mx-auto w-full p-4 pb-32">
    <h3 class="font-bold text-xl mb-6">Recent Orders</h3>

    <div class="space-y-4">
        <% if (orders.length === 0) { %>
            <div class="text-center py-12 bg-white rounded-xl border border-gray-200">
                <div class="text-4xl mb-2">📦</div>
                <p class="text-gray-500">No orders yet. They will appear here once customers checkout.</p>
            </div>
        <% } else { %>
            <% orders.forEach(order => { %>
                <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
                    <div class="flex justify-between items-start mb-3">
                        <div>
                            <div class="font-black text-lg">₦<%= order.total.toLocaleString() %></div>
                            <div class="text-xs text-gray-400"><%= new Date(order.created_at).toLocaleString() %></div>
                        </div>
                        <form action="/admin/orders/status/<%= order.$loki %>" method="POST">
                            <select name="status" onchange="this.form.submit()" class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded 
                                <% if (order.status === 'pending') { %>bg-yellow-100 text-yellow-700<% } 
                                else if (order.status === 'completed') { %>bg-green-100 text-green-700<% } 
                                else { %>bg-red-100 text-red-700<% } %>
                                ">
                                <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                            </select>
                        </form>
                    </div>

                    <div class="border-t border-gray-100 pt-3 mb-3">
                        <div class="text-sm font-bold mb-1"><%= order.customer_name %></div>
                        <div class="text-xs text-gray-500 mb-1">📞 <%= order.customer_phone %></div>
                        <div class="text-xs text-gray-500 italic">📍 <%= order.customer_address %></div>
                    </div>

                    <div class="bg-gray-50 rounded-lg p-3">
                        <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Items</div>
                        <% order.items.forEach(item => { %>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-600"><%= item.name %> x<%= item.quantity %> <%= item.variant ? `(${item.variant})` : '' %></span>
                                <span class="font-bold">₦<%= (item.price * item.quantity).toLocaleString() %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</main>
