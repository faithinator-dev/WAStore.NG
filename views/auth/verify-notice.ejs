<div class="container py-5">
  <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-sm p-4 p-lg-5 text-center rounded-4">
        <div class="mb-4">
          <div class="bg-wa-light text-wa rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 100px; height: 100px;">
            <i class="fa fa-envelope-open-text fs-1"></i>
          </div>
          <h2 class="fw-bold mb-3">Verify Your Email</h2>
          <p class="text-muted">
            We've sent a verification link to <br>
            <strong class="text-dark"><%= vendor.email %></strong>
          </p>
        </div>

        <p class="small text-muted mb-4">
          Please click the link in your email to activate your showroom and access your dashboard. 
          If you don't see it, check your <strong>Spam</strong> folder.
        </p>

        <form action="/auth/resend-verification" method="POST" class="mb-4">
          <button type="submit" class="btn btn-wa w-100 py-3 rounded-pill fw-bold shadow-sm">
            Resend Verification Email
          </button>
        </form>

        <div class="pt-4 border-top">
          <p class="text-center text-muted small mb-0">
            Entered the wrong email? <a href="/auth/signup" class="text-wa fw-bold text-decoration-none">Create a new account</a>
          </p>
          <a href="/auth/logout" class="btn btn-link btn-sm text-muted mt-2 text-decoration-none" onclick="event.preventDefault(); document.getElementById('logout-form').submit()">Logout</a>
          <form id="logout-form" action="/auth/logout" method="POST" style="display: none;"></form>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .bg-wa-light { background-color: rgba(37, 211, 102, 0.1); }
  .text-wa { color: #25D366; }
  .btn-wa { background-color: #25D366; color: white; border: none; }
  .btn-wa:hover { background-color: #128C7E; color: white; }
</style>