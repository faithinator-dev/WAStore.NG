<div class="container py-5">
  <div class="row align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="col-md-6 col-lg-5">
      <div class="text-center mb-4">
        <h1 class="fw-bold text-wa">WaStore</h1>
        <p class="text-muted">Recover your account access.</p>
      </div>
      
      <div class="card p-4 shadow border-0">
        <h2 class="h4 fw-bold mb-3">Forgot Password</h2>
        <p class="text-muted small mb-4">Enter your email address and we'll send you a link to reset your password.</p>
        
        <% if (errors) { %>
          <% errors.forEach(err => { %>
            <div class="alert alert-danger py-2 small"><%= err.msg %></div>
          <% }) %>
        <% } %>

        <form action="/auth/forgot-password" method="POST">
          <div class="mb-4">
            <label class="form-label fw-semibold small">EMAIL ADDRESS</label>
            <input type="email" name="email" class="form-control form-control-lg border-light-subtle bg-light" placeholder="e.g. contact@business.com" required>
          </div>
          <button type="submit" class="btn btn-wa w-100 py-3 mb-3">Send Reset Link <i class="fa fa-paper-plane ms-1 small"></i></button>
        </form>
        
        <p class="text-center text-muted small mb-0">
          Remembered your password? <a href="/auth/login" class="text-wa fw-bold text-decoration-none">Back to Login</a>
        </p>
      </div>
    </div>
  </div>
</div>
