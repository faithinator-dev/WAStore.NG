<div class="container py-5">
  <div class="row align-items-center justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="text-center mb-4">
        <h1 class="fw-bold text-wa">WaStore</h1>
        <p class="text-muted">Start selling on WhatsApp in 2 minutes.</p>
      </div>
      
      <div class="card p-4 shadow border-0">
        <h2 class="h4 fw-bold mb-4">Create Your Store</h2>
        
        <% if (errors) { %>
          <% errors.forEach(err => { %>
            <div class="alert alert-danger py-2 small"><%= err.msg %></div>
          <% }) %>
        <% } %>

        <form action="/auth/signup" method="POST">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
          <div class="mb-3">
            <label class="form-label fw-semibold small">BUSINESS NAME</label>
            <input type="text" name="businessName" class="form-control border-light-subtle bg-light" placeholder="e.g. Olamide Motors" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">FULL NAME</label>
            <input type="text" name="ownerName" class="form-control border-light-subtle bg-light" placeholder="Your name" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">WHATSAPP NUMBER</label>
            <input type="tel" name="phone" class="form-control border-light-subtle bg-light" placeholder="e.g. 2348123456789" required>
            <div class="form-text small">Include country code (e.g. 234)</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">EMAIL ADDRESS</label>
            <input type="email" name="email" class="form-control border-light-subtle bg-light" placeholder="e.g. contact@business.com" required>
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold small">CREATE PASSWORD</label>
            <input type="password" name="password" class="form-control border-light-subtle bg-light" placeholder="Min. 8 characters" required>
          </div>
          <button type="submit" class="btn btn-wa w-100 py-3 mb-3">Launch My Store <i class="fa fa-rocket ms-1"></i></button>
        </form>
        
        <p class="text-center text-muted small mb-0">
          Already have a store? <a href="/auth/login" class="text-wa fw-bold text-decoration-none">Sign In</a>
        </p>
      </div>
    </div>
  </div>
</div>
