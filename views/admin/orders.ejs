<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <nav class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse px-3 pt-4 min-vh-100">
      <div class="mb-5 px-3">
        <h2 class="fw-bold text-success mb-0">WaStore</h2>
        <p class="small text-muted">Platform Admin</p>
      </div>
      
      <div class="nav flex-column">
        <a class="nav-link text-white-50 mb-2" href="/admin">
          <i class="fa fa-chart-line me-2"></i> Overview
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/vendors">
          <i class="fa fa-store me-2"></i> Vendors
        </a>
        <a class="nav-link text-white active mb-2" href="/admin/orders">
          <i class="fa fa-receipt me-2"></i> All Orders
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/settings">
          <i class="fa fa-user-shield me-2"></i> System Settings
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 bg-light">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 fw-bold">Platform Orders <i class="fa fa-receipt small text-muted"></i></h1>
      </div>

      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="bg-white">
              <tr class="small text-muted fw-bold border-bottom">
                <th class="ps-4 py-3">ORDER REF</th>
                <th>VENDOR</th>
                <th>CUSTOMER</th>
                <th>TOTAL</th>
                <th>STATUS</th>
                <th>PAYMENT</th>
                <th class="pe-4">DATE</th>
              </tr>
            </thead>
            <tbody>
              <% if (orders.length > 0) { %>
                <% orders.forEach(order => { %>
                  <tr class="bg-white">
                    <td class="ps-4">
                      <div class="fw-bold text-dark"><%= order.orderNumber %></div>
                      <div class="smaller text-muted">#<%= order._id.toString().slice(-6) %></div>
                    </td>
                    <td>
                      <div class="fw-bold"><%= order.vendor ? order.vendor.businessName : 'Unknown Vendor' %></div>
                    </td>
                    <td>
                      <div><%= order.customer ? order.customer.fullName : 'Guest' %></div>
                    </td>
                    <td>
                      <div class="fw-bold">₦<%= order.total.toLocaleString() %></div>
                    </td>
                    <td>
                      <span class="badge rounded-pill px-2 
                        <%= order.status === 'pending' ? 'bg-warning-subtle text-warning' : '' %>
                        <%= order.status === 'confirmed' ? 'bg-primary-subtle text-primary' : '' %>
                        <%= order.status === 'delivered' ? 'bg-success-subtle text-success' : '' %>
                        border border-opacity-10">
                        <%= order.status.toUpperCase() %>
                      </span>
                    </td>
                    <td>
                      <% if (order.payment.status === 'paid') { %>
                        <span class="text-success small"><i class="fa fa-check-circle me-1"></i> Paid</span>
                      <% } else { %>
                        <span class="text-muted small"><i class="fa fa-clock me-1"></i> Unpaid</span>
                      <% } %>
                    </td>
                    <td class="small text-muted pe-4">
                      <%= new Date(order.createdAt).toLocaleDateString() %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <i class="fa fa-receipt fa-4x text-light mb-3"></i>
                    <p class="text-muted">No orders found across the platform.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .bg-dark { background-color: #1a1d21 !important; }
  .nav-link:hover { background: rgba(255,255,255,0.1); }
  .smaller { font-size: 0.75rem; }
</style>
