<div class="container-fluid">
  <div class="row">
    <!-- Admin Sidebar (Re-used for consistency) -->
    <nav class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse px-3 pt-4 min-vh-100">
      <div class="mb-5 px-3">
        <h2 class="fw-bold text-success mb-0">WaStore</h2>
        <p class="small text-muted">Platform Admin</p>
      </div>
      
      <div class="nav flex-column">
        <a class="nav-link text-white-50 mb-2" href="/admin">
          <i class="fa fa-chart-line me-2"></i> Overview
        </a>
        <a class="nav-link text-white active mb-2" href="/admin/vendors">
          <i class="fa fa-store me-2"></i> Vendors
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/orders">
          <i class="fa fa-receipt me-2"></i> All Orders
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/settings">
          <i class="fa fa-user-shield me-2"></i> System Settings
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 bg-light">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 fw-bold">Manage Vendors <i class="fa fa-store small text-muted"></i></h1>
        <div class="input-group w-auto">
          <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted"></i></span>
          <input type="text" class="form-control border-start-0" placeholder="Search businesses...">
        </div>
      </div>

      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="bg-white">
              <tr class="small text-muted fw-bold border-bottom">
                <th class="ps-4 py-3">BUSINESS NAME</th>
                <th>OWNER / EMAIL</th>
                <th>VERIFICATION</th>
                <th>STATUS</th>
                <th>JOINED</th>
                <th class="text-end pe-4">ACTIONS</th>
              </tr>
            </thead>
            <tbody>
              <% vendors.forEach(v => { %>
                <tr class="bg-white">
                  <td class="ps-4">
                    <div class="fw-bold text-dark"><%= v.businessName %></div>
                    <div class="small text-wa">https://wastore-ng.onrender.com/store/<%= v.slug %></div>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= v.ownerName %></div>
                    <div class="small text-muted"><%= v.email %></div>
                  </td>
                  <td>
                    <% if (v.isVerified) { %>
                      <span class="badge bg-success-subtle text-success rounded-pill px-3">
                        <i class="fa fa-check-circle me-1"></i> Verified
                      </span>
                    <% } else { %>
                      <span class="badge bg-warning-subtle text-warning rounded-pill px-3">
                        <i class="fa fa-clock me-1"></i> Pending
                      </span>
                    <% } %>
                  </td>
                  <td>
                    <% if (v.isActive) { %>
                      <span class="text-success"><i class="fa fa-circle small me-1"></i> Active</span>
                    <% } else { %>
                      <span class="text-danger"><i class="fa fa-circle small me-1"></i> Deactivated</span>
                    <% } %>
                  </td>
                  <td class="small text-muted">
                    <%= new Date(v.createdAt).toLocaleDateString() %>
                  </td>
                  <td class="text-end pe-4">
                    <div class="dropdown">
                      <button class="btn btn-light btn-sm border" data-bs-toggle="dropdown">
                        <i class="fa fa-ellipsis-h"></i>
                      </button>
                      <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <% if (!v.isVerified) { %>
                          <li>
                            <form action="/admin/vendors/<%= v._id %>/verify" method="POST">
                              <button type="submit" class="dropdown-item py-2 text-success">
                                <i class="fa fa-certificate me-2"></i> Verify Vendor
                              </button>
                            </form>
                          </li>
                        <% } %>
                        <li>
                          <form action="/admin/vendors/<%= v._id %>/toggle-status" method="POST">
                            <button type="submit" class="dropdown-item py-2 <%= v.isActive ? 'text-danger' : 'text-primary' %>">
                              <i class="fa <%= v.isActive ? 'fa-ban' : 'fa-play' %> me-2"></i> 
                              <%= v.isActive ? 'Deactivate Account' : 'Reactivate Account' %>
                            </button>
                          </form>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2" href="mailto:<%= v.email %>"><i class="fa fa-envelope me-2"></i> Email Vendor</a></li>
                      </ul>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .text-wa { color: #25D366; }
  .bg-dark { background-color: #1a1d21 !important; }
  .nav-link:hover { background: rgba(255,255,255,0.1); }
</style>
