<div class="container-fluid">
  <div class="row">
    <!-- Admin Sidebar -->
    <nav class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse px-3 pt-4 min-vh-100">
      <div class="mb-5 px-3">
        <h2 class="fw-bold text-success mb-0">WaStore</h2>
        <p class="small text-muted">Platform Admin</p>
      </div>
      
      <div class="nav flex-column">
        <a class="nav-link text-white active mb-2" href="/admin">
          <i class="fa fa-chart-line me-2"></i> Overview
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/vendors">
          <i class="fa fa-store me-2"></i> Vendors
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/orders">
          <i class="fa fa-receipt me-2"></i> All Orders
        </a>
        <a class="nav-link text-white-50 mb-2" href="/admin/settings">
          <i class="fa fa-user-shield me-2"></i> System Settings
        </a>
        
        <div class="mt-5 pt-5 border-top border-secondary">
          <form action="/auth/logout" method="POST">
            <button type="submit" class="nav-link text-danger border-0 bg-transparent">
              <i class="fa fa-sign-out-alt me-2"></i> Logout
            </button>
          </form>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 bg-light">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4">
        <h1 class="h2 fw-bold text-dark">Platform Overview <i class="fa fa-globe small text-muted"></i></h1>
      </div>

      <!-- Stats Cards -->
      <div class="row g-4 mb-5">
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
              <div class="bg-primary-subtle text-primary rounded-3 p-3 me-3">
                <i class="fa fa-store fs-4"></i>
              </div>
              <div>
                <div class="small text-muted fw-bold">TOTAL VENDORS</div>
                <div class="h3 fw-bold mb-0"><%= stats.totalVendors %></div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
              <div class="bg-success-subtle text-success rounded-3 p-3 me-3">
                <i class="fa fa-shopping-bag fs-4"></i>
              </div>
              <div>
                <div class="small text-muted fw-bold">TOTAL ORDERS</div>
                <div class="h3 fw-bold mb-0"><%= stats.totalOrders %></div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
              <div class="bg-info-subtle text-info rounded-3 p-3 me-3">
                <i class="fa fa-naira-sign fs-4"></i>
              </div>
              <div>
                <div class="small text-muted fw-bold">PLATFORM GMV</div>
                <div class="h3 fw-bold mb-0">₦<%= stats.totalRevenue.toLocaleString() %></div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
              <div class="bg-warning-subtle text-warning rounded-3 p-3 me-3">
                <i class="fa fa-box fs-4"></i>
              </div>
              <div>
                <div class="small text-muted fw-bold">TOTAL PRODUCTS</div>
                <div class="h3 fw-bold mb-0"><%= stats.totalProducts %></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-lg-8">
          <div class="card border-0 shadow-sm overflow-hidden mb-4">
            <div class="card-header bg-white py-3">
              <h5 class="fw-bold mb-0">Recent Vendor Registrations</h5>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead class="bg-light">
                  <tr class="small text-muted fw-bold">
                    <th class="ps-4">BUSINESS</th>
                    <th>OWNER</th>
                    <th>PHONE</th>
                    <th>PLAN</th>
                    <th class="text-end pe-4">ACTION</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentVendors.forEach(v => { %>
                    <tr>
                      <td class="ps-4">
                        <div class="fw-bold"><%= v.businessName %></div>
                        <div class="small text-muted">@<%= v.slug %></div>
                      </td>
                      <td><%= v.ownerName %></td>
                      <td><%= v.phone %></td>
                      <td><span class="badge bg-light text-dark border"><%= v.plan.toUpperCase() %></span></td>
                      <td class="text-end pe-4">
                        <a href="/admin/vendors" class="btn btn-sm btn-outline-dark">View All</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card border-0 shadow-sm p-4 bg-success text-white mb-4">
            <h5 class="fw-bold mb-3">Quick Actions</h5>
            <div class="d-grid gap-2">
              <a href="/admin/vendors" class="btn btn-light fw-bold">Review Verifications</a>
              <button class="btn btn-dark fw-bold">Export Platform Data</button>
            </div>
          </div>
          
          <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3">System Health</h5>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted small">Database Status</span>
              <span class="badge bg-<%= stats.dbStatus === 'Online' ? 'success' : 'danger' %>"><%= stats.dbStatus %></span>
            </div>
            <div class="d-flex justify-content-between">
              <span class="text-muted small">Mail Server</span>
              <span class="badge bg-success">Connected</span>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .nav-link:hover { background: rgba(255,255,255,0.1); }
  .bg-dark { background-color: #1a1d21 !important; }
</style>
