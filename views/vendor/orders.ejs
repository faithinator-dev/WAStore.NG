<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse px-3 pt-4">
      <div class="mb-5 px-3">
        <h2 class="fw-bold text-wa mb-0">WaStore</h2>
        <p class="small text-muted">Admin Panel</p>
      </div>
      
      <div class="nav flex-column">
        <a class="nav-link-wa" href="/dashboard">
          <i class="fa fa-th-large"></i> Overview
        </a>
        <a class="nav-link-wa" href="/dashboard/products">
          <i class="fa fa-box"></i> Inventory
        </a>
        <a class="nav-link-wa active" href="/dashboard/orders">
          <i class="fa fa-shopping-bag"></i> Orders
        </a>
        <a class="nav-link-wa" href="/dashboard/customers">
          <i class="fa fa-users"></i> Customers
        </a>
        <a class="nav-link-wa" href="/dashboard/settings">
          <i class="fa fa-cog"></i> Settings
        </a>
        
        <div class="mt-5 pt-5 border-top">
          <a class="nav-link-wa text-danger" href="#" onclick="document.getElementById('logout-form').submit()">
            <i class="fa fa-sign-out-alt"></i> Logout
          </a>
          <form id="logout-form" action="/auth/logout" method="POST" style="display: none;"></form>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4">
        <div>
          <h1 class="h2 fw-bold mb-1">Orders <i class="fa fa-receipt small text-muted"></i></h1>
          <p class="text-muted small mb-0">Track and manage your customer requests</p>
        </div>
        <div class="btn-toolbar mb-2 mb-md-0">
          <div class="btn-group me-2">
            <a href="/dashboard/orders/export" class="btn btn-sm btn-outline-secondary px-3"><i class="fa fa-download me-2"></i>Export CSV</a>
          </div>
        </div>
      </div>

      <!-- Quick Filters -->
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex gap-2" id="orderFilters">
                <button class="btn btn-wa-filter active" data-filter="all">All Orders</button>
                <button class="btn btn-wa-filter" data-filter="pending">Pending</button>
                <button class="btn btn-wa-filter" data-filter="confirmed">Confirmed</button>
                <button class="btn btn-wa-filter" data-filter="delivered">Delivered</button>
                <button class="btn btn-wa-filter" data-filter="cancelled">Cancelled</button>
              </div>
            </div>
            <div class="col-md-4 mt-3 mt-md-0">
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Search order ref or customer...">
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr class="small text-muted fw-bold">
                <th class="ps-4 py-3">ORDER REF</th>
                <th>DATE</th>
                <th>CUSTOMER</th>
                <th>METHOD</th>
                <th>ITEMS</th>
                <th>TOTAL</th>
                <th>STATUS</th>
                <th class="text-end pe-4">ACTION</th>
              </tr>
            </thead>
            <tbody>
              <% if (orders.length > 0) { %>
                <% orders.forEach(order => { %>
                  <tr class="order-row" data-status="<%= order.status %>">
                    <td class="ps-4">
                      <div class="fw-bold text-dark"><%= order.orderNumber %></div>
                      <div class="text-wa small fw-bold">#<%= order._id.toString().slice(-6) %></div>
                    </td>
                    <td class="small">
                      <div class="text-dark"><%= order.createdAt.toLocaleDateString('en-NG', { day: 'numeric', month: 'short' }) %></div>
                      <div class="text-muted"><%= order.createdAt.toLocaleTimeString('en-NG', { hour: '2-digit', minute: '2-digit' }) %></div>
                    </td>
                    <td>
                      <div class="fw-bold text-dark"><%= order.customer ? order.customer.fullName : 'Guest User' %></div>
                      <div class="text-muted small"><%= order.customer ? order.customer.phone : 'No phone' %></div>
                    </td>
                    <td>
                      <% if (order.checkoutMethod === 'whatsapp') { %>
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                          <i class="fab fa-whatsapp me-1"></i> WhatsApp
                        </span>
                      <% } else { %>
                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill">
                          <i class="fa fa-credit-card me-1"></i> Card
                        </span>
                      <% } %>
                    </td>
                    <td>
                      <div class="small fw-bold text-dark"><%= order.items.length %> Item<%= order.items.length > 1 ? 's' : '' %></div>
                      <div class="text-muted smaller" style="font-size: 0.75rem;">
                        <%= order.items.slice(0, 2).map(i => i.name).join(', ') %>
                        <%= order.items.length > 2 ? '...' : '' %>
                      </div>
                    </td>
                    <td>
                      <div class="fw-bold text-dark">₦<%= order.total.toLocaleString() %></div>
                      <div class="text-muted smaller" style="font-size: 0.75rem;"><%= order.payment && order.payment.status === 'paid' ? 'Paid' : 'Unpaid' %></div>
                    </td>
                    <td>
                      <span class="badge rounded-pill p-2 px-3 
                        <%= order.status === 'pending' ? 'bg-warning-subtle text-warning' : '' %>
                        <%= order.status === 'confirmed' ? 'bg-primary-subtle text-primary' : '' %>
                        <%= order.status === 'delivered' ? 'bg-success-subtle text-success' : '' %>
                        <%= order.status === 'cancelled' ? 'bg-danger-subtle text-danger' : '' %>
                        border border-opacity-10">
                        <i class="fa fa-circle small me-1"></i> <%= order.status.toUpperCase() %>
                      </span>
                    </td>
                    <td class="text-end pe-4">
                      <div class="dropdown">
                        <button class="btn btn-light btn-sm rounded-circle border p-0" style="width: 32px; height: 32px;" data-bs-toggle="dropdown">
                          <i class="fa fa-ellipsis-v small"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                          <li><a class="dropdown-item py-2" href="/dashboard/orders/<%= order._id %>"><i class="fa fa-eye me-2"></i> View Details</a></li>
                          <li><hr class="dropdown-divider"></li>
                          <% if (order.status === 'pending') { %>
                            <li>
                              <form action="/dashboard/orders/<%= order._id %>/status?_method=PATCH" method="POST">
                                <input type="hidden" name="status" value="confirmed">
                                <button class="dropdown-item py-2" type="submit"><i class="fa fa-check text-success me-2"></i> Confirm Order</button>
                              </form>
                            </li>
                          <% } %>
                          <% if (order.status !== 'delivered' && order.status !== 'cancelled') { %>
                            <li>
                              <form action="/dashboard/orders/<%= order._id %>/status?_method=PATCH" method="POST">
                                <input type="hidden" name="status" value="delivered">
                                <button class="dropdown-item py-2" type="submit"><i class="fa fa-truck text-info me-2"></i> Mark Delivered</button>
                              </form>
                            </li>
                          <% } %>
                          <% if (order.status !== 'cancelled' && order.status !== 'delivered') { %>
                            <li>
                              <form action="/dashboard/orders/<%= order._id %>/status?_method=PATCH" method="POST">
                                <input type="hidden" name="status" value="cancelled">
                                <button class="dropdown-item py-2 text-danger" type="submit"><i class="fa fa-times me-2"></i> Cancel Order</button>
                              </form>
                            </li>
                          <% } %>
                        </ul>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="8" class="text-center py-5">
                    <div class="py-4">
                      <i class="fa fa-shopping-basket fa-4x text-light mb-3"></i>
                      <h5 class="text-muted">No orders found yet</h5>
                      <p class="text-muted small">When customers place orders, they will appear here.</p>
                      <a href="/store/<%= vendor.slug %>" target="_blank" class="btn btn-wa mt-2 rounded-pill px-4">Test Storefront</a>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .btn-wa-filter {
    border: 1px solid #e1e9ee;
    background: white;
    color: #54656f;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    transition: all 0.2s ease;
  }
  .btn-wa-filter:hover, .btn-wa-filter.active {
    background-color: var(--wa-light);
    color: var(--wa-dark);
    border-color: var(--wa-green);
  }
  .smaller {
    font-size: 0.75rem;
  }
  .table thead th {
    letter-spacing: 0.05em;
    font-size: 0.75rem;
  }
</style>

<script>
  // Simple search and filter logic
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.querySelector('input[placeholder*="Search"]');
    const filterButtons = document.querySelectorAll('.btn-wa-filter');
    const rows = document.querySelectorAll('.order-row');

    function updateView() {
      const searchTerm = searchInput.value.toLowerCase();
      const activeFilter = document.querySelector('.btn-wa-filter.active').dataset.filter;

      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        const status = row.dataset.status;
        const matchesSearch = text.includes(searchTerm);
        const matchesFilter = activeFilter === 'all' || status === activeFilter;

        row.style.display = (matchesSearch && matchesFilter) ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', updateView);

    filterButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        filterButtons.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        updateView();
      });
    });
  });
</script>
