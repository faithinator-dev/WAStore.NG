<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse px-3 pt-4">
      <div class="mb-5 px-3">
        <h2 class="fw-bold text-wa mb-0">WaStore</h2>
        <p class="small text-muted">Admin Panel</p>
      </div>
      
      <div class="nav flex-column">
        <a class="nav-link-wa" href="/dashboard">
          <i class="fa fa-th-large"></i> Overview
        </a>
        <a class="nav-link-wa active" href="/dashboard/products">
          <i class="fa fa-box"></i> Inventory
        </a>
        <a class="nav-link-wa" href="/dashboard/orders">
          <i class="fa fa-shopping-bag"></i> Orders
        </a>
        <a class="nav-link-wa" href="/dashboard/customers">
          <i class="fa fa-users"></i> Customers
        </a>
        <a class="nav-link-wa" href="/dashboard/settings">
          <i class="fa fa-cog"></i> Settings
        </a>
        
        <div class="mt-5 pt-5 border-top">
          <a class="nav-link-wa text-danger" href="#" onclick="document.getElementById('logout-form').submit()">
            <i class="fa fa-sign-out-alt"></i> Logout
          </a>
          <form id="logout-form" action="/auth/logout" method="POST" style="display: none;"></form>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4">
        <div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
              <li class="breadcrumb-item"><a href="/dashboard" class="text-wa text-decoration-none">Dashboard</a></li>
              <li class="breadcrumb-item"><a href="/dashboard/products" class="text-wa text-decoration-none">Inventory</a></li>
              <li class="breadcrumb-item active" aria-current="page">Add Product</li>
            </ol>
          </nav>
          <h1 class="h2 fw-bold">Add New Product <i class="fa fa-box-open small text-muted"></i></h1>
        </div>
      </div>

      <% if (locals.errors) { %>
        <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4">
          <ul class="mb-0">
            <% errors.forEach(err => { %>
              <li><%= err.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="row">
        <div class="col-lg-8">
          <div class="card p-4 border-0 shadow-sm mb-4">
            <form action="/dashboard/products/add" method="POST" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
              <div class="mb-4">
                <label class="form-label fw-bold text-muted small">PRODUCT NAME</label>
                <input type="text" name="name" class="form-control form-control-lg border-light-subtle bg-light" placeholder="e.g. Vintage Leather Bag" required>
              </div>

              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label class="form-label fw-bold text-muted small">PRICE (₦)</label>
                  <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white border-light-subtle">₦</span>
                    <input type="number" name="price" class="form-control border-light-subtle bg-light" placeholder="15,000" required>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold text-muted small">COMPARE AT PRICE (OPTIONAL)</label>
                  <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white border-light-subtle">₦</span>
                    <input type="number" name="compareAtPrice" class="form-control border-light-subtle bg-light" placeholder="20,000">
                  </div>
                  <small class="text-muted">Shows as a strikethrough "Was" price</small>
                </div>
              </div>

              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label class="form-label fw-bold text-muted small">STOCK STATUS</label>
                  <select name="stockStatus" class="form-select form-select-lg border-light-subtle bg-light">
                    <option value="in_stock">In Stock</option>
                    <option value="sold_out">Sold Out</option>
                    <option value="pre_order">Pre-Order</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold text-muted small">STOCK QUANTITY (OPTIONAL)</label>
                  <input type="number" name="quantity" class="form-control form-control-lg border-light-subtle bg-light" placeholder="e.g. 50">
                  <small class="text-muted">Leave blank for unlimited stock</small>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold text-muted small">DESCRIPTION</label>
                <textarea name="description" class="form-control border-light-subtle bg-light" rows="6" placeholder="Tell your customers about this product, its features, and benefits..."></textarea>
              </div>

              <!-- Media Selection -->
              <div class="mb-4">
                <label class="form-label fw-bold text-muted small">PRODUCT IMAGE</label>
                <div class="card bg-light border-dashed p-4 text-center mb-3" id="drop-area">
                  <div id="image-preview" class="mb-3 d-none">
                    <img src="" alt="Preview" class="img-fluid rounded-3" style="max-height: 200px;">
                  </div>
                  <div id="upload-prompt">
                    <i class="fa fa-cloud-upload-alt fa-3x text-wa mb-3"></i>
                    <p class="mb-0">Drag & drop your product image here, or</p>
                    <label for="image_file" class="text-wa fw-bold cursor-pointer" style="cursor: pointer;">browse files</label>
                    <input type="file" name="image_file" id="image_file" class="d-none" accept="image/*">
                  </div>
                </div>
                <div class="text-center text-muted small mb-3">— OR —</div>
                <div class="input-group">
                  <span class="input-group-text bg-white border-light-subtle"><i class="fa fa-link text-muted"></i></span>
                  <input type="text" name="image_url" class="form-control border-light-subtle bg-light" placeholder="Paste image URL (e.g. https://...)">
                </div>
              </div>

              <div class="pt-4 border-top mt-5 d-flex gap-3">
                <button type="submit" class="btn btn-wa btn-lg px-5 py-3 shadow">
                  <i class="fa fa-check me-2"></i> Publish Product
                </button>
                <a href="/dashboard" class="btn btn-light btn-lg px-5 py-3">
                  Cancel
                </a>
              </div>
            </form>
          </div>
        </div>

        <!-- Tips Sidebar -->
        <div class="col-lg-4">
          <div class="card p-4 border-0 bg-light-subtle shadow-sm mb-4">
            <h5 class="fw-bold mb-3"><i class="fa fa-lightbulb text-warning me-2"></i> Quick Tips</h5>
            <ul class="list-unstyled mb-0 small text-muted">
              <li class="mb-3 d-flex align-items-start">
                <i class="fa fa-info-circle mt-1 me-2 text-wa"></i>
                <span>Use clear, high-quality images to increase sales by up to 60%.</span>
              </li>
              <li class="mb-3 d-flex align-items-start">
                <i class="fa fa-info-circle mt-1 me-2 text-wa"></i>
                <span>Compare prices help show value to your customers.</span>
              </li>
              <li class="d-flex align-items-start">
                <i class="fa fa-info-circle mt-1 me-2 text-wa"></i>
                <span>Detailed descriptions reduce customer questions in your DM.</span>
              </li>
            </ul>
          </div>

          <div class="card p-4 border-0 shadow-sm">
            <h5 class="fw-bold mb-3">Preview</h5>
            <p class="small text-muted mb-4">This is how your product will roughly appear in your showroom.</p>
            <div class="product-card rounded-4 overflow-hidden border shadow-sm bg-white">
              <div class="bg-light" style="height: 180px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-image fa-3x text-muted"></i>
              </div>
              <div class="p-3">
                <div class="fw-bold mb-1" id="preview-name">Product Name</div>
                <div class="text-wa fw-bold">₦0.00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .border-dashed {
    border: 2px dashed #e1e9ee;
  }
  .bg-light-subtle {
    background-color: #f8f9fa !important;
  }
  .breadcrumb-item + .breadcrumb-item::before {
    content: "›";
    font-size: 1.2rem;
    line-height: 1;
    vertical-align: middle;
  }
</style>

<script>
  // Simple image preview
  const fileInput = document.getElementById('image_file');
  const preview = document.getElementById('image-preview');
  const previewImg = preview.querySelector('img');
  const uploadPrompt = document.getElementById('upload-prompt');

  fileInput.addEventListener('change', function() {
    const file = this.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        previewImg.src = e.target.result;
        preview.classList.remove('d-none');
        uploadPrompt.classList.add('d-none');
      }
      reader.readAsDataURL(file);
    }
  });

  // Dynamic preview text
  document.querySelector('input[name="name"]').addEventListener('input', function() {
    document.getElementById('preview-name').textContent = this.value || 'Product Name';
  });
</script>
