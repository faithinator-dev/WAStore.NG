<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">Customer Database 👥</h1>
    <button class="btn btn-outline-wa rounded-pill px-4">
      <i class="fa fa-download me-2"></i> Export CSV
    </button>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr class="small text-muted fw-bold">
            <th class="ps-4">CUSTOMER NAME</th>
            <th>WHATSAPP NUMBER</th>
            <th>EMAIL</th>
            <th>TOTAL SPENT</th>
            <th>ORDERS</th>
            <th class="text-end pe-4">LAST ORDER</th>
          </tr>
        </thead>
        <tbody>
          <% if (customers.length > 0) { %>
            <% customers.forEach(customer => { %>
              <tr>
                <td class="ps-4">
                  <div class="fw-bold text-wa"><%= customer.fullName %></div>
                </td>
                <td>
                  <a href="https://wa.me/<%= customer.phone %>" target="_blank" class="text-decoration-none text-dark fw-semibold">
                    <i class="fab fa-whatsapp text-success me-1"></i> <%= customer.phone %>
                  </a>
                </td>
                <td><%= customer.email || '—' %></td>
                <td class="fw-bold">₦<%= customer.totalSpend.toLocaleString() %></td>
                <td><span class="badge bg-wa-light text-wa"><%= customer.totalOrders %> orders</span></td>
                <td class="text-end pe-4 text-muted small"><%= customer.lastOrderAt ? customer.lastOrderAt.toLocaleDateString() : '—' %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-5">
                <i class="fa fa-users fa-3x text-light mb-3"></i>
                <p class="text-muted mb-0">Your customer list will grow as you receive orders.</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
