<div class="max-w-md mx-auto w-full px-4 py-20">
    <h1 class="text-3xl font-bold mb-2">Create your store</h1>
    <p class="text-gray-600 mb-8">Set up your catalog in 60 seconds.</p>
    <form action="/signup" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-bold mb-1">Shop Name</label>
            <input type="text" name="shop_name" placeholder="Mama Aisha Spices" required class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">WhatsApp Number</label>
            <input type="tel" name="whatsapp" placeholder="2348012345678" required class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Email (Optional - for notifications)</label>
            <input type="email" name="email" placeholder="vendor@gmail.com" class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
        </div>
        <div>
            <label class="block text-sm font-bold mb-1">Set Password</label>
            <input type="password" name="password" required placeholder="••••••••" class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
        </div>
        <button type="submit" class="w-full tap-target bg-[#25D366] text-white font-bold text-lg mt-4 shadow-lg">Create My Store</button>
    </form>
    <p class="text-center mt-6 text-sm text-gray-500">
        Already have a store? <a href="/signin" class="text-emerald-600 font-bold">Sign In</a>
    </p>
</div>
