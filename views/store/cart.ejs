<div class="bg-white sticky-top shadow-sm border-bottom">
  <div class="container py-3 d-flex align-items-center">
    <a href="/store/<%= store.slug %>" class="btn btn-light rounded-pill border py-2 me-3">
      <i class="fa fa-arrow-left"></i>
    </a>
    <h5 class="mb-0 fw-bold">Shopping Cart</h5>
  </div>
</div>

<div class="container py-4 mb-5" style="max-width: 700px;">
  <div id="cart-container">
    <!-- JS Content -->
  </div>
</div>

<script>
  function renderCart() {
    const items = Cart.get();
    const container = document.getElementById('cart-container');
    
    if (items.length === 0) {
      container.innerHTML = `
        <div class="text-center py-5">
          <div class="bg-white p-5 rounded-4 shadow-sm">
            <i class="fa fa-shopping-basket fa-4x text-light mb-4"></i>
            <h3 class="fw-bold">Your cart is empty</h3>
            <p class="text-muted mb-4">Looks like you haven't added any items to your cart yet.</p>
            <a href="/store/<%= store.slug %>" class="btn btn-wa px-5 py-2">Start Shopping</a>
          </div>
        </div>
      `;
      return;
    }

    let subtotal = 0;
    let html = '<div class="card border-0 shadow-sm p-3 p-lg-4 mb-4">';
    
    items.forEach(item => {
      const lineTotal = item.price * item.quantity;
      subtotal += lineTotal;
      const itemKey = Cart.getItemKey(item);
      const variantsHtml = item.selectedVariants ? 
        Object.entries(item.selectedVariants).map(([k, v]) => `<span class="badge bg-light text-dark me-1 border small fw-normal">${k}: ${v}</span>`).join('') : '';

      html += `
        <div class="d-flex align-items-center py-3 border-bottom last-child-border-0">
          <img src="${item.image}" class="rounded-3 me-3" style="width: 70px; height: 70px; object-fit: cover;">
          <div class="flex-grow-1">
            <h6 class="fw-bold mb-1">${item.name}</h6>
            <div class="mb-2">${variantsHtml}</div>
            <div class="d-flex align-items-center mt-2">
              <div class="input-group input-group-sm" style="width: 100px;">
                <button class="btn btn-outline-secondary border-light-subtle" onclick="Cart.updateQuantity('${itemKey}', -1)">-</button>
                <input type="text" class="form-control text-center bg-white border-light-subtle" value="${item.quantity}" readonly>
                <button class="btn btn-outline-secondary border-light-subtle" onclick="Cart.updateQuantity('${itemKey}', 1)">+</button>
              </div>
              <div class="ms-3 text-wa fw-bold small">₦${item.price.toLocaleString()}</div>
            </div>
          </div>
          <div class="text-end">
            <div class="fw-bold mb-2">₦${lineTotal.toLocaleString()}</div>
            <button onclick="Cart.remove('${itemKey}')" class="btn btn-light btn-sm text-danger rounded-pill px-3 border-0">
              <i class="fa fa-trash-alt"></i> Remove
            </button>
          </div>
        </div>
      `;
    });

    html += `
      <div class="pt-4 mt-2">
        <div class="d-flex justify-content-between h4 fw-bold mb-4">
          <span>Subtotal</span>
          <span class="text-wa">₦${subtotal.toLocaleString()}</span>
        </div>
        <a href="/store/<%= store.slug %>/checkout" class="btn btn-wa w-100 py-3 fs-5">
          Proceed to Checkout
        </a>
      </div>
    </div>`;

    container.innerHTML = html;
  }

  document.addEventListener('DOMContentLoaded', renderCart);
  window.addEventListener('cartUpdated', renderCart);
</script>

<style>
  .last-child-border-0:last-child { border-bottom: none !important; }
</style>
