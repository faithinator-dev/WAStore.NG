<!-- Order Success Page -->
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="text-center mb-5">
        <div class="mb-4">
          <i class="fas fa-check-circle text-wa" style="font-size: 80px;"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">Order Confirmed!</h1>
        <p class="lead text-muted mb-4">
          Thank you for your purchase. Your order has been successfully created.
        </p>
      </div>

      <!-- Order Details -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-4"><i class="fa fa-clipboard-list text-wa me-2"></i> Order Details</h5>
          <div class="row mb-3">
            <div class="col-md-6">
              <p class="mb-2"><strong>Order ID:</strong></p>
              <p class="text-wa font-monospace fw-bold"><%= order.orderNumber %></p>
            </div>
            <div class="col-md-6">
              <p class="mb-2"><strong>Date:</strong></p>
              <p><%= new Date(order.createdAt).toLocaleDateString() %></p>
            </div>
          </div>
          <hr>
          <div class="row">
            <div class="col-md-6">
              <p class="mb-2"><strong>Total Amount:</strong></p>
              <h4 class="text-wa">₦<%= order.total.toLocaleString() %></h4>
            </div>
            <div class="col-md-6">
              <p class="mb-2"><strong>Status:</strong></p>
              <span class="badge bg-info">Pending</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Items Ordered -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-4"><i class="fa fa-shopping-cart text-wa me-2"></i> Items Ordered</h5>
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Quantity</th>
                  <th>Price</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% order.items.forEach(item => { %>
                  <tr>
                    <td><%= item.name %></td>
                    <td><%= item.quantity %></td>
                    <td>₦<%= item.price.toLocaleString() %></td>
                    <td>₦<%= (item.price * item.quantity).toLocaleString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Buyer Info -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-4"><i class="fa fa-user text-wa me-2"></i> Delivery Information</h5>
          <p class="mb-2"><strong>Name:</strong> <%= order.deliveryAddress.fullName %></p>
          <p class="mb-2"><strong>Email:</strong> <%= order.deliveryAddress.email || 'N/A' %></p>
          <p class="mb-2"><strong>Phone:</strong> <%= order.deliveryAddress.phone %></p>
          <p class="mb-0"><strong>Address:</strong> <%= order.deliveryAddress.addressLine1 %></p>
        </div>
      </div>

      <!-- Next Steps -->
      <div class="alert alert-info mb-4" role="alert">
        <h6 class="alert-heading"><i class="fa fa-mobile-alt text-wa me-2"></i> What happens next?</h6>
        <p class="mb-2">The vendor will contact you on WhatsApp or via the provided phone number to confirm your order and arrange payment.</p>
        <p class="mb-0"><strong>Order ID:</strong> <%= order.orderNumber %> (Share this with the vendor)</p>
      </div>

      <!-- Actions -->
      <div class="d-flex gap-3 justify-content-center">
        <a href="/store/<%= store.slug %>" class="btn btn-outline-wa btn-lg rounded-pill">
          <i class="fas fa-shopping-bag me-2"></i> Continue Shopping
        </a>
        <a href="https://wa.me/<%= store.phone.replace(/[^0-9]/g, '') %>?text=Order%20ID:%20<%= order.orderNumber %>" target="_blank" class="btn btn-wa btn-lg rounded-pill">
          <i class="fab fa-whatsapp me-2"></i> Contact Vendor
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .text-wa { color: #25D366; }
  .btn-wa { background-color: #25D366; border: none; }
  .btn-wa:hover { background-color: #075E54; color: white; }
  .btn-outline-wa { border: 2px solid #25D366; color: #25D366; }
  .btn-outline-wa:hover { background-color: #25D366; color: white; }
  .font-monospace { font-family: 'Courier New', monospace; }
</style>
