<!-- Store Navbar -->
<nav class="navbar navbar-light sticky-top nav-wa-glass">
  <div class="container">
    <a class="navbar-brand fw-bold text-vendor-primary" href="#">
      <%= store.businessName %>
    </a>
    <a href="/store/<%= store.slug %>/cart" class="btn btn-wa position-relative rounded-pill">
      <i class="fa fa-shopping-cart"></i>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cart-count">0</span>
    </a>
  </div>
</nav>

<!-- Hero Section -->
<header class="bg-white py-5 mb-4 border-bottom">
  <div class="container text-center">
    <% if (store.storefront.logoUrl) { %>
      <img src="<%= store.storefront.logoUrl %>" alt="Logo" class="mb-3" style="max-height: 100px;">
    <% } %>
    <h1 class="display-5 fw-bold text-vendor-primary"><%= store.businessName %></h1>
    <p class="lead text-vendor-primary opacity-75"><%= store.storefront.tagline %></p>
  </div>
</header>

<div class="container">
  <!-- Search -->
  <div class="row mb-4 justify-content-center">
    <div class="col-md-6">
      <form action="/store/<%= store.slug %>" method="GET" class="input-group">
        <input type="text" name="search" class="form-control form-control-lg border-wa" placeholder="Search Product..." value="<%= search %>">
        <button class="btn btn-wa px-4" type="submit"><i class="fa fa-search"></i></button>
      </form>
    </div>
  </div>

  <!-- Catalog Grid -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% if (products.length > 0) { %>
      <% products.forEach(product => { %>
        <div class="col">
          <div class="card h-100 shadow-sm border-0">
            <a href="/store/<%= store.slug %>/product/<%= product._id %>">
              <img src="<%= product.primaryImage %>" class="card-img-top" alt="<%= product.name %>" style="aspect-ratio: 16/10; object-fit: cover; border-top-left-radius: 15px; border-top-right-radius: 15px;">
            </a>
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= product.name %></h5>
              <p class="card-text text-muted text-truncate"><%= product.description %></p>
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <span class="h5 fw-bold text-wa">₦<%= product.price.toLocaleString() %></span>
                  <% if (product.compareAtPrice) { %>
                    <br><small class="text-decoration-line-through text-muted">₦<%= product.compareAtPrice.toLocaleString() %></small>
                  <% } %>
                </div>
                <a href="/store/<%= store.slug %>/product/<%= product._id %>" class="btn btn-wa">View Details</a>
              </div>
            </div>
            <% if (product.stockStatus === 'sold_out') { %>
              <div class="position-absolute top-0 end-0 m-2 badge bg-danger">SOLD OUT</div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="fa fa-shopping-basket fa-4x text-light mb-3"></i>
        <p class="h4 text-muted">No products available at the moment.</p>
      </div>
    <% } %>
  </div>
</div>

<footer class="py-5 mt-5 bg-white text-center">
  <p class="text-muted small">&copy; 2026 <%= store.businessName %> | Powered by WaStore</p>
</footer>

<style>
  :root {
    --vendor-primary: <%= store.storefront.themeColor || '#25D366' %>;
  }
  .nav-wa-glass { 
    background-color: rgba(255, 255, 255, 0.9) !important; 
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .text-vendor-primary { color: var(--vendor-primary) !important; }
  .text-wa { color: var(--vendor-primary) !important; }
  .btn-wa { background-color: var(--vendor-primary); color: white; border: none; }
  .btn-wa:hover { opacity: 0.9; color: white; }
  .border-wa { border-color: var(--vendor-primary) !important; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const items = Cart.get();
    document.getElementById('cart-count').innerText = items ? items.length : 0;
  });
</script>
