<!-- Store Navbar -->
<nav class="navbar navbar-light sticky-top nav-wa-glass">
  <div class="container">
    <a class="navbar-brand fw-bold text-vendor-primary" href="#">
      <%= store.businessName %>
    </a>
    <a href="/store/<%= store.slug %>/cart" class="btn btn-wa position-relative rounded-pill">
      <i class="fa fa-shopping-cart"></i>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cart-count">0</span>
    </a>
  </div>
</nav>

<!-- Hero Section -->
<header class="bg-white py-5 mb-4 border-bottom">
  <div class="container text-center">
    <% if (store.storefront.logoUrl) { %>
      <img src="<%= store.storefront.logoUrl %>" alt="Logo" class="mb-3" style="max-height: 100px;">
    <% } %>
    <h1 class="display-5 fw-bold text-vendor-primary"><%= store.businessName %></h1>
    <p class="lead text-vendor-primary opacity-75"><%= store.storefront.tagline %></p>
  </div>
</header>

<div class="container">
  <!-- Search & Filter Bar -->
  <div class="row mb-4 g-3 align-items-center">
    <div class="col-md-6 col-lg-7">
      <form action="/store/<%= store.slug %>" method="GET" class="input-group">
        <input type="text" name="search" class="form-control border-wa rounded-start-pill px-4" placeholder="Search products..." value="<%= search %>">
        <% if (selectedCategory) { %><input type="hidden" name="category" value="<%= selectedCategory %>"><% } %>
        <button class="btn btn-wa px-4 rounded-end-pill" type="submit"><i class="fa fa-search"></i></button>
      </form>
    </div>
    <div class="col-md-3 col-lg-2">
      <select class="form-select border-wa rounded-pill" onchange="location.href='/store/<%= store.slug %>?sort=' + this.value + '<%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %>'">
        <option value="displayOrder" <%= sort === 'displayOrder' ? 'selected' : '' %>>Recommended</option>
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest</option>
        <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
        <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
      </select>
    </div>
    <div class="col-md-3 col-lg-3 text-end">
      <div class="dropdown">
        <button class="btn btn-outline-wa rounded-pill px-4 dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
          <%= selectedCategory || 'All Categories' %>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 p-2">
          <li><a class="dropdown-item rounded-3 <%= !selectedCategory ? 'active' : '' %>" href="/store/<%= store.slug %>">All Categories</a></li>
          <% categories.forEach(cat => { %>
            <li><a class="dropdown-item rounded-3 <%= selectedCategory === cat ? 'active' : '' %>" href="/store/<%= store.slug %>?category=<%= encodeURIComponent(cat) %>"><%= cat %></a></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>

  <!-- Catalog Grid -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    <% if (products.length > 0) { %>
      <% products.forEach(product => { %>
        <div class="col">
          <div class="card h-100 shadow-sm border-0 product-card">
            <a href="/store/<%= store.slug %>/product/<%= product._id %>" class="position-relative overflow-hidden">
              <img src="<%= product.primaryImage %>" class="card-img-top" alt="<%= product.name %>" style="aspect-ratio: 1/1; object-fit: cover;">
              <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
                <span class="position-absolute top-0 start-0 m-2 badge bg-danger rounded-pill px-2 py-1">SALE</span>
              <% } %>
            </a>
            <div class="card-body">
              <h6 class="card-title fw-bold mb-1 text-truncate"><%= product.name %></h6>
              <div class="d-flex align-items-center mb-3">
                <span class="fw-bold text-wa">₦<%= product.price.toLocaleString() %></span>
                <% if (product.compareAtPrice) { %>
                  <small class="text-decoration-line-through text-muted ms-2">₦<%= product.compareAtPrice.toLocaleString() %></small>
                <% } %>
              </div>
              <button class="btn btn-wa w-100 rounded-pill py-2 small fw-bold" 
                onclick="Cart.add({ productId: '<%= product._id %>', name: '<%= product.name.replace(/'/g, "\\'") %>', price: <%= product.price %>, image: '<%= product.primaryImage %>' })">
                <i class="fa fa-shopping-cart me-2"></i> Add to Cart
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="fa fa-shopping-basket fa-4x text-light mb-3"></i>
        <p class="h4 text-muted">No products found matching your criteria.</p>
        <a href="/store/<%= store.slug %>" class="btn btn-wa mt-3 rounded-pill px-5">View All Products</a>
      </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (pagination.pages > 1) { %>
    <nav class="mt-5">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
          <a class="page-link rounded-circle mx-1" href="?page=<%= pagination.page - 1 %><%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %><%= sort ? '&sort=' + sort : '' %>">
            <i class="fa fa-chevron-left"></i>
          </a>
        </li>
        <% for(let i = 1; i <= pagination.pages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link rounded-circle mx-1" href="?page=<%= i %><%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %><%= sort ? '&sort=' + sort : '' %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
          <a class="page-link rounded-circle mx-1" href="?page=<%= pagination.page + 1 %><%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %><%= sort ? '&sort=' + sort : '' %>">
            <i class="fa fa-chevron-right"></i>
          </a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>

<footer class="py-5 mt-5 bg-white text-center">
  <p class="text-muted small">&copy; 2026 <%= store.businessName %> | Powered by WaStore</p>
</footer>

<style>
  :root {
    --vendor-primary: <%= store.storefront.themeColor || '#25D366' %>;
  }
  .nav-wa-glass { 
    background-color: rgba(255, 255, 255, 0.9) !important; 
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .text-vendor-primary { color: var(--vendor-primary) !important; }
  .text-wa { color: var(--vendor-primary) !important; }
  .btn-wa { background-color: var(--vendor-primary); color: white; border: none; }
  .btn-wa:hover { opacity: 0.9; color: white; }
  .border-wa { border-color: var(--vendor-primary) !important; }
</style>

<script>
  function addToCartAndNotify(product) {
    Cart.add(product);
    const items = Cart.get();
    document.getElementById('cart-count').innerText = items ? items.length : 0;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const items = Cart.get();
    document.getElementById('cart-count').innerText = items ? items.length : 0;
  });
</script>
