<!-- Store Catalog Page -->
<header class="bg-wa text-white sticky-top shadow-sm" style="background-color: #25D366;">
    <div class="container py-4">
        <h1 class="display-5 fw-bold mb-2"><%= vendor.businessName || vendor.shop_name || 'Store' %></h1>
        <div class="small text-white-50">
            <% if (vendor.state) { %>
                <i class="fas fa-map-marker-alt me-2"></i><%= vendor.state %>
            <% } %>
            <% if (vendor.storefront && vendor.storefront.socialLinks && vendor.storefront.socialLinks.instagram) { %>
                <span class="ms-3">
                    <i class="fab fa-instagram me-1"></i>
                    <a href="https://instagram.com/<%= vendor.storefront.socialLinks.instagram %>" target="_blank" class="text-white-50">
                        @<%= vendor.storefront.socialLinks.instagram %>
                    </a>
                </span>
            <% } %>
        </div>
    </div>
</header>

<!-- Store Description -->
<div class="bg-light border-bottom">
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-8">
                <% if (vendor.storefront && vendor.storefront.about) { %>
                    <p class="text-muted mb-0"><%= vendor.storefront.about %></p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Products Section -->
<main class="container py-5 flex-grow">
    <% if (!products || products.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
            <h3 class="h5 text-muted">No Products Available</h3>
            <p class="text-muted small">The vendor hasn't uploaded any products yet. Check back soon!</p>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% products.forEach(p => { %>
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="card product-card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <!-- Product Image -->
                        <div class="product-image-container position-relative" style="height: 220px;">
                            <img src="<%= p.image_url || 'https://via.placeholder.com/400x400/e5e7eb/999999?text=No+Image' %>" 
                                 alt="<%= p.name %>" class="img-fluid w-100 h-100" style="object-fit: cover;" loading="lazy">
                            
                            <% if (p.stockStatus === 'out_of_stock' || p.stock === 0) { %>
                                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center">
                                    <span class="badge bg-light text-dark px-3 py-2 fs-6">Out of Stock</span>
                                </div>
                            <% } %>
                        </div>

                        <!-- Product Info -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= p.name %></h5>
                            
                            <% if (p.description) { %>
                                <p class="card-text text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    <%= p.description %>
                                </p>
                            <% } %>

                            <!-- Variants -->
                            <% if (p.variants && Array.isArray(p.variants) && p.variants.length > 0) { %>
                                <div class="mb-3">
                                    <select id="variant-<%= p._id %>" class="form-select form-select-sm rounded-2">
                                        <option value="">Select variant</option>
                                        <% p.variants.forEach(v => { %>
                                            <option value="<%= v %>"><%= v %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            <% } %>

                            <!-- Price & Action -->
                            <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                                <div class="h5 mb-0 text-wa fw-bold">₦<%= Number(p.price).toLocaleString('en-NG') %></div>
                                
                                <% if (p.stockStatus !== 'out_of_stock' && p.stock > 0) { %>
                                    <button onclick="addToCart({id: '<%= p._id %>', name: '<%= p.name.replace(/'/g, "\\'") %>', price: <%= p.price %>, image: '<%= p.image_url %>', variant: document.getElementById('variant-<%= p._id %>')?.value || null})" 
                                            class="btn btn-wa btn-sm rounded-circle" title="Add to Cart">
                                        <i class="fas fa-shopping-cart"></i>
                                    </button>
                                <% } else { %>
                                    <a href="https://wa.me/<%= vendor.phone %>?text=Hi, when will <%= p.name %> be back in stock?" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill small">
                                        Notify
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</main>

<!-- Floating Cart Button -->
<div class="fixed-bottom mb-4 me-4">
    <button onclick="toggleCart()" class="btn btn-wa btn-lg rounded-circle shadow-lg position-relative" title="View Cart" id="cartButton" style="display: none;">
        <i class="fas fa-shopping-cart"></i>
        <span id="cartCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
    </button>
</div>

<!-- Cart Drawer -->
<div id="cartDrawer" class="position-fixed top-0 end-0 h-100 bg-white shadow-lg d-flex flex-column" 
     style="width: 100%; max-width: 400px; z-index: 1050; transform: translateX(100%); transition: transform 0.3s ease;">
    
    <div class="sticky-top bg-white border-bottom p-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Your Order</h5>
            <button onclick="toggleCart()" class="btn-close"></button>
        </div>
    </div>

    <div id="cartItems" class="p-3 flex-grow-1 overflow-y-auto">
        <p class="text-center text-muted py-5">Your cart is empty</p>
    </div>

    <div class="position-sticky bottom-0 bg-white border-top p-3">
        <div class="mb-3">
            <p class="mb-1 text-muted small">SUBTOTAL</p>
            <h4 class="text-wa mb-3">₦<span id="cartTotal">0</span></h4>
            <a href="/checkout?store=<%= vendor.slug %>" class="btn btn-wa w-100 rounded-pill fw-bold py-2">
                Proceed to Checkout
            </a>
        </div>
    </div>
</div>

<!-- Styles -->
<style>
    .text-wa { color: #25D366 !important; }
    .bg-wa { background-color: #25D366 !important; }
    .btn-wa {
        background-color: #25D366;
        color: white;
        border: none;
        font-weight: 600;
    }
    .btn-wa:hover {
        background-color: #075E54;
        color: white;
    }
    .product-image-container {
        overflow: hidden;
    }
    .product-image-container img {
        transition: transform 0.3s ease;
    }
    .product-card:hover .product-image-container img {
        transform: scale(1.05);
    }
    .form-select-sm {
        font-size: 0.875rem;
    }
</style>

<!-- Cart Management Script -->
<script>
function addToCart(product) {
    let cart = JSON.parse(localStorage.getItem('wastore_cart') || '[]');
    const existingItem = cart.find(item => item.id === product.id && item.variant === (product.variant || ''));
    
    if (existingItem) {
        existingItem.quantity += 1;
    } else {
        cart.push({ ...product, quantity: 1 });
    }
    
    localStorage.setItem('wastore_cart', JSON.stringify(cart));
    renderCart();
    showNotification('Added to cart!');
}

function removeFromCart(productId, variant) {
    let cart = JSON.parse(localStorage.getItem('wastore_cart') || '[]');
    cart = cart.filter(item => !(item.id === productId && item.variant === variant));
    localStorage.setItem('wastore_cart', JSON.stringify(cart));
    renderCart();
}

function updateQuantity(productId, variant, quantity) {
    if (quantity <= 0) {
        removeFromCart(productId, variant);
        return;
    }
    
    let cart = JSON.parse(localStorage.getItem('wastore_cart') || '[]');
    const item = cart.find(item => item.id === productId && item.variant === variant);
    if (item) item.quantity = quantity;
    localStorage.setItem('wastore_cart', JSON.stringify(cart));
    renderCart();
}

function renderCart() {
    const cart = JSON.parse(localStorage.getItem('wastore_cart') || '[]');
    const cartItems = document.getElementById('cartItems');
    const cartCount = document.getElementById('cartCount');
    const cartButton = document.getElementById('cartButton');
    const cartTotal = document.getElementById('cartTotal');
    
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    cartCount.textContent = totalItems;
    cartButton.style.display = totalItems > 0 ? 'block' : 'none';
    
    let total = 0;
    
    if (cart.length === 0) {
        cartItems.innerHTML = '<p class="text-center text-muted py-5">Your cart is empty</p>';
        cartTotal.textContent = '0';
        return;
    }
    
    cartItems.innerHTML = cart.map(item => {
        const itemTotal = item.price * item.quantity;
        total += itemTotal;
        return `
            <div class="border-bottom pb-3 mb-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h6 class="mb-0 fw-bold">${item.name}</h6>
                        ${item.variant ? `<small class="text-muted">${item.variant}</small>` : ''}
                    </div>
                    <button onclick="removeFromCart('${item.id}', '${item.variant || ''}')" class="btn btn-sm btn-link text-danger">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="input-group input-group-sm" style="width: 100px;">
                        <button class="btn btn-light" onclick="updateQuantity('${item.id}', '${item.variant || ''}', ${item.quantity - 1})">-</button>
                        <input type="text" class="form-control text-center" value="${item.quantity}" readonly>
                        <button class="btn btn-light" onclick="updateQuantity('${item.id}', '${item.variant || ''}', ${item.quantity + 1})">+</button>
                    </div>
                    <div class="text-wa fw-bold">₦${(item.price * item.quantity).toLocaleString('en-NG')}</div>
                </div>
            </div>
        `;
    }).join('');
    
    cartTotal.textContent = total.toLocaleString('en-NG');
}

function toggleCart() {
    const drawer = document.getElementById('cartDrawer');
    const isOpen = drawer.style.transform === 'translateX(0px)';
    drawer.style.transform = isOpen ? 'translateX(100%)' : 'translateX(0)';
}

function showNotification(message) {
    const alert = document.createElement('div');
    alert.className = 'alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3';
    alert.style.zIndex = '1060';
    alert.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 3000);
}

// Initialize cart on page load
document.addEventListener('DOMContentLoaded', () => {
    renderCart();
});
</script>

    function toggleCart() {
        const drawer = document.getElementById('cartDrawer');
        drawer.classList.toggle('hidden');
    }

    function checkout() {
        const address = document.getElementById('buyerAddress').value.trim();
        const customerName = document.getElementById('buyerName').value.trim();
        const customerPhone = document.getElementById('buyerPhone').value.trim();
        
        if (!address || !customerName || !customerPhone) return alert("Please fill all details to continue!");
        
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/checkout';
        
        const fields = {
            vendor_id: '<%= vendor.$loki %>',
            customer_name: customerName,
            customer_phone: customerPhone,
            customer_address: address,
            cart_data: JSON.stringify(cart)
        };
        
        for (const key in fields) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = fields[key];
            form.appendChild(input);
        }
        
        document.body.appendChild(form);
        form.submit();
        
        localStorage.removeItem('wastore_cart');
    }

    updateUI();
</script>
